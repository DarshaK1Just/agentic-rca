# ─────────────────────────────────────────────────────────────────────────────
# Streamlit Cloud Secrets Configuration
#
# HOW TO USE THIS FILE:
# 1. DO NOT commit this file to GitHub (it contains secrets)
# 2. In your Streamlit Cloud workspace dashboard:
#    - Click "Settings" → "Secrets"
#    - Copy the contents of this file (after replacing YOUR_KEY_HERE with real keys)
#    - Paste into the Streamlit Cloud secrets editor
# 3. Your app will automatically load these on Streamlit Cloud
#
# For local development, use .env file instead (see .env.example)
# ─────────────────────────────────────────────────────────────────────────────

# Which LLM provider: gemini | openrouter | ollama
RCA_LLM_PROVIDER = "gemini"

# Google AI Studio (FREE) — Get key at https://aistudio.google.com/apikey
GOOGLE_API_KEY = "AIzaSy...YOUR_KEY_HERE..."
RCA_GEMINI_MODEL = "gemini-2.5-flash"
RCA_GEMINI_BASE_URL = "https://generativelanguage.googleapis.com/v1beta/openai/"

# Optional: OpenRouter (FREE tier available)
# Uncomment and set RCA_LLM_PROVIDER = "openrouter" to use
# OPENROUTER_API_KEY = "sk-or-v1-...YOUR_KEY_HERE..."
# RCA_OPENROUTER_MODEL = "deepseek/deepseek-r1:free"

# Embeddings (no key needed — runs locally)
RCA_EMBED_MODEL = "sentence-transformers/all-MiniLM-L6-v2"
