# ── BYOK configuration — copy to `.env` and fill in. NEVER commit real keys. ──
#
# The engine reads keys from the environment only (see src/rca/agent/llm_provider.py).
# Pick ONE provider via RCA_LLM_PROVIDER; the rest are optional fallbacks.

# Which provider drives reasoning + synthesis: gemini | openrouter | ollama
RCA_LLM_PROVIDER=gemini

# --- Google AI Studio (primary). Free key: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=
RCA_GEMINI_MODEL=gemini-2.5-flash

# --- OpenRouter (fallback). Free key: https://openrouter.ai/keys
OPENROUTER_API_KEY=
RCA_OPENROUTER_MODEL=deepseek/deepseek-r1:free

# --- Ollama (offline fallback). Install: https://ollama.com  then `ollama pull llama3.1`
RCA_OLLAMA_BASE_URL=http://localhost:11434/v1
RCA_OLLAMA_MODEL=llama3.1

# Embeddings run locally by default (sentence-transformers, no key needed).
RCA_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2
